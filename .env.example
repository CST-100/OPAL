# OPAL Configuration
# Copy this file to .env and modify as needed

# Server
OPAL_HOST=0.0.0.0
OPAL_PORT=8080
OPAL_DEBUG=false

# Database
OPAL_DATABASE_URL=sqlite:///./data/opal.db

# Security
OPAL_ALLOWED_ORIGINS=*
OPAL_RATE_LIMIT_ENABLED=false
OPAL_RATE_LIMIT_REQUESTS=100
OPAL_RATE_LIMIT_WINDOW=60

# Authentication
OPAL_AUTH_MODE=local

# File uploads
OPAL_UPLOAD_DIR=./data/attachments
OPAL_MAX_UPLOAD_SIZE=10485760
OPAL_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,application/pdf,text/plain,text/csv
